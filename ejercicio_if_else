            opcion = Console.ReadLine();

            switch (opcion)
            {
                case "A":
                    Console.WriteLine("Has seleccionado el rol de Administrador.");
                    Console.WriteLine("Llevar el control total del sistema, incluyendo la gestión de usuarios, configuración y mantenimiento.");
                    break;
                case "E":
                    Console.WriteLine("Has seleccionado el rol de Editor.");

            Console.WriteLine("8. conversor de usuario (roles de sistema)");
            Console.WriteLine("9. Dispensador automático de bebidas");
            Console.WriteLine("10. Indenticador de estaciones del año");
            Console.WriteLine("11. salir");
            Console.WriteLine("Elija el numero del ejercicio que desea ejecutar:");

            opcion = int.Parse(Console.ReadLine());

            switch (opcion)
            {
                case 1:
                    verificacion_Edad();
                    break;
                case 2:
                    Sistemas_calificaciones_Escolares();
                    break;
                case 3:
                    Verificador_Pares_Impares();
                    break;
                case 4:

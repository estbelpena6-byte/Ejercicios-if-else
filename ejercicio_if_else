    static void verificacion_Edad()
        {
            
            Console.WriteLine("--------- verificación de Edad-----------");

            Console.WriteLine("Ingrese su edad:");
            int edad = int.Parse(Console.ReadLine());
            if (edad >= 18)
            {
                Console.WriteLine("Eres mayor de edad.");
            }
            else
            {
                Console.WriteLine("Eres menor de edad.");
            }
        }
        

        static void Sistemas_calificaciones_Escolares()
        {
            Console.WriteLine("Ingrese la calificación del estudiante (0-100):");
            int calificacion = int.Parse(Console.ReadLine());
            if (calificacion >= 90)
            {
                Console.WriteLine("Calificación: A");
            }
            else if (calificacion >= 80)
            {
                Console.WriteLine("Calificación: B");
            }
            else if (calificacion >= 70)
            {
                Console.WriteLine("Calificación: C");
            }
            else if (calificacion >= 60)
            {
                Console.WriteLine("Calificación: D");
            }
            else
            {
                Console.WriteLine("Calificación: F");
            }
        }
        static void Verificador_Pares_Impares()
        {
            Console.WriteLine("Ingrese un número:");
            int numero = int.Parse(Console.ReadLine());
            if (numero % 2 == 0)
            {
                Console.WriteLine("El número es par.");
            }
            else
            {
                Console.WriteLine("El número es impar.");
            }
        }
        static void Simulador_Cajero_Automatico()
        {
            Console.WriteLine("Ingrese el monto a retirar:");
            decimal monto = decimal.Parse(Console.ReadLine());
            decimal saldo = 1000m; // Saldo inicial del cajero
            if (monto <= saldo)
            {
                saldo -= monto;
                Console.WriteLine($"Retiro exitoso. Saldo restante: {saldo:C}");
            }
            else
            {
                Console.WriteLine("Fondo insuficiente para realizar el retiro.");
            }
        }

        static void Calificador_temperatura_ambiental()
        {
            Console.WriteLine("Ingrese la temperatura ambiental en grados Celsius:");
            int temperatura = int.Parse(Console.ReadLine());
            if (temperatura < 15)
            {
                Console.WriteLine("Clima Frio");
            }
            else if (15 <= temperatura && temperatura < 28)
            {
                Console.WriteLine("Clima Templado");
            }
            else if (temperatura >= 28)
            {
                Console.WriteLine("Clima Caliente");
            }
        }
        static void Selector_dias_semana()
        {
            Console.WriteLine("Ingrese un número del 1 al 7 para seleccionar un día de la semana:");
            int dia = int.Parse(Console.ReadLine());
            switch (dia)
            {
                case 1:
                    Console.WriteLine("Lunes");
                    break;
                case 2:
                    Console.WriteLine("Martes");
                    break;
                case 3:
                    Console.WriteLine("Miércoles");
                    break;
                case 4:
                    Console.WriteLine("Jueves");
                    break;
                case 5:
                    Console.WriteLine("Viernes");
                    break;
                case 6:
                    Console.WriteLine("Sábado");
                    break;
                case 7:
                    Console.WriteLine("Domingo");
                    break;
                default:
                    Console.WriteLine("Número no válido. Por favor, ingrese un número del 1 al 7.");
                    break;
            }
        }
        static void Calculadora_básica_operaciones()
        {
            Console.WriteLine("Ingrese el primer número:");
            double num1 = double.Parse(Console.ReadLine());
            Console.WriteLine("Ingrese el segundo número:");
            double num2 = double.Parse(Console.ReadLine());
            Console.WriteLine("Seleccione la operación (+, -, *, /):");
            string operacion = Console.ReadLine();
            double resultado;
            switch (operacion)
            {
                case "+":
                    resultado = num1 + num2;
                    Console.WriteLine($"Resultado: {resultado}");
                    break;
                case "-":
                    resultado = num1 - num2;
                    Console.WriteLine($"Resultado: {resultado}");
                    break;
                case "*":
                    resultado = num1 * num2;
                    Console.WriteLine($"Resultado: {resultado}");
                    break;
                case "/":
                    if (num2 != 0)
                    {
                        resultado = num1 / num2;
                        Console.WriteLine($"Resultado: {resultado}");
                    }
                    else
                    {
                        Console.WriteLine("Error: No se puede dividir por cero.");
                    }
                    break;
                default:
                    Console.WriteLine("Operación no válida. Por favor, seleccione una operación válida.");
                    break;
            }
        }
